{
  "expo": {
    "name": "IgiciroHub",
    "slug": "igicirohub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "igicirohub",
    "userInterfaceStyle": "dark",
    "privacy": "public",
    "privacyPolicyUrl": "https://isherve.github.io/IgiciroHub/privacy/",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "rw.igicirohub.app",
      "supportsTablet": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to photograph coffee plants for disease symptom guidance.",
        "NSPhotoLibraryUsageDescription": "Used to upload coffee plant photos for AI analysis."
      }
    },
    "android": {
      "package": "rw.igicirohub.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B140F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d39d62af-ba46-4e00-8db5-53347e6530df"
      }
    },
    "owner": "isherve",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d39d62af-ba46-4e00-8db5-53347e6530df"
    }
  }
}

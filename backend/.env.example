# ---------------------------------------------------------------------------
# IgiciroHub backend environment. Copy to `.env` and fill in real values.
# NEVER commit the real .env file.
# ---------------------------------------------------------------------------

# Django
DJANGO_SETTINGS_MODULE=igicirohub.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# CORS / client origins (Expo dev + web)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081

# JWT lifetimes (minutes / days)
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (SMTP) — leave blank to use console backend in dev
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@igicirohub.rw

# Google Gemini (AI assistant + disease detection). Optional.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Africa's Talking (SMS alerts). Optional.
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
